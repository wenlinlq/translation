# 语音技术（ASR / TTS）— 百度智能云「语音技术」应用
BAIDU_SPEECH_API_KEY=your_speech_api_key
BAIDU_SPEECH_SECRET_KEY=your_speech_secret_key

# 机器翻译 — 百度智能云「机器翻译」应用
BAIDU_MT_APP_ID=your_mt_app_id
BAIDU_MT_SECRET=your_mt_secret

# ASR：百度短语音单次≤60秒；默认 1537。80001 需控制台开通
# BAIDU_ASR_DEV_PID=1537
# BAIDU_ASR_USE_PRO=1

# TTS 发音人 per：5118=度小鹿精品女声，4194=度嫣然大模型，4105=度灵儿(英语)
# BAIDU_TTS_PER=5118
# BAIDU_TTS_SPD=5
# BAIDU_TTS_VOL=8

# 默认语言（可在界面修改）
SOURCE_LANG=zh
TARGET_LANG=en

PORT=3000
