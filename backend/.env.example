# 语音技术（ASR / TTS）— 百度智能云「语音技术」应用
BAIDU_SPEECH_API_KEY=your_speech_api_key
BAIDU_SPEECH_SECRET_KEY=your_speech_secret_key

# 机器翻译 — 百度智能云「机器翻译」应用
BAIDU_MT_APP_ID=your_mt_app_id
BAIDU_MT_SECRET=your_mt_secret

# 对象存储 BOS（音频文件转写必填：先上传 BOS 再识别）
BOS_ACCESS_KEY_ID=your_bos_access_key
BOS_SECRET_ACCESS_KEY=your_bos_secret_key
BOS_BUCKET=your_bucket_name
BOS_REGION=bj
# BOS_ENDPOINT=https://bj.bcebos.com
# BOS_PREFIX=translation/asr/
# BOS_PUBLIC_READ=0
# BOS_URL_EXPIRES_SEC=86400
# BOS_DELETE_AFTER_ASR=1

# 音频文件转写 pid：80006=中文音视频字幕，1737=英文
# BAIDU_AASR_PID=80006
# AASR_POLL_MAX_MS=600000
# AASR_POLL_INTERVAL_MS=3000

# TTS（中文/英语目标）百度发音人 per：5118=度小鹿，4105=度灵儿（英语）
# BAIDU_TTS_PER=5118

# TTS（日语/韩语等）使用 Edge 多语种，无需密钥；可选：
# TTS_EDGE_MULTILINGUAL_VOICE=en-US-EmmaMultilingualNeural
# TTS_EDGE_VOICE=ko-KR-SunHiNeural
# TTS_EDGE_NATIVE_TIMEOUT_MS=20000

SOURCE_LANG=zh
TARGET_LANG=en
PORT=3000
